# ---------------------------------------------------------------------------
# Environment variables for the Data Engineering Glossary.
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# Most values are stubs at Phase 0 — they get wired up in later phases.
# ---------------------------------------------------------------------------

# --- Database (Supabase Postgres) ---
# Pooled connection (PgBouncer) — used by the app at runtime for Prisma queries.
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true"
# Direct connection (no pooler) — used by Prisma for migrations.
DIRECT_URL="postgresql://user:password@host:5432/postgres"

# --- Supabase: public values (safe to expose to the browser) ---
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# --- Supabase: server-only secret (NEVER expose to the browser) ---
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# --- Admin auth allowlist (comma-separated emails) ---
ADMIN_EMAILS="you@example.com"

# --- Gemini API (enrichment pipeline) ---
GEMINI_API_KEY="your-gemini-api-key"

# --- Enrichment webhook (Next.js → FastAPI) ---
ENRICHMENT_WEBHOOK_URL="http://localhost:8000/enrich"
# Shared secret sent with the webhook; FastAPI rejects requests without it.
ENRICHMENT_WEBHOOK_SECRET="generate-a-long-random-string"